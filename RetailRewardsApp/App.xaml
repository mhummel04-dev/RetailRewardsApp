<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RetailRewardsApp"
             x:Class="RetailRewardsApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <OnPlatform x:TypeArguments="x:String" x:Key="SelectedBusinessFont">
                <On Platform="iOS" Value="OpenSansRegular" />
                <On Platform="Android" Value="OpenSansRegular" />
            </OnPlatform>
        </ResourceDictionary>
    </Application.Resources>
</Application>
