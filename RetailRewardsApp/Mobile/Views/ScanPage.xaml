<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.ScanPage"
             Title="ScanPage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to your QR code!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Label
            Text="{Binding BindingUser.PhoneNumber, StringFormat='{0}'}"
            />
        
    </VerticalStackLayout>
</ContentPage>