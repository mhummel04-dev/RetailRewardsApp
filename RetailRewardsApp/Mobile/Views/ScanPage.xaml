<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.ScanPage"
             Title="ScanPage">
    
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
        
        <Label Text="Align QR Code within the frame" HorizontalOptions="Center" />

        <Border Stroke="Gray" StrokeThickness="2" HeightRequest="250" WidthRequest="250">
            <Image Source="sample_qrcode.png" 
               Aspect="AspectFit" 
               Opacity="0.5" />
        </Border>

        <Button Text="Flashlight" WidthRequest="150" />
        
    </VerticalStackLayout>
    
</ContentPage>