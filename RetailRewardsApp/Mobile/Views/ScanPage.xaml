<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.ScanPage"
             Title="ScanPage">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">

        <Label Text="Scan this QR code at the store!" HorizontalOptions="Center" />

        <Border Stroke="Gray" StrokeThickness="2" HeightRequest="250" WidthRequest="250">
            <Image Source="{Binding QrImageSource}" 
               WidthRequest="250" 
               HeightRequest="250" 
               HorizontalOptions="Center" />
        </Border>
        
    </VerticalStackLayout>
</ContentPage>