<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.HomePage"
             xmlns:models="RetailRewardsApp.Core.Models"
             xmlns:vm="clr-namespace:RetailRewardsApp.Mobile.ViewModels"
             Title="HomePage">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto" ColumnDefinitions="*" Padding="24">

        <VerticalStackLayout Grid.Row="0"
                             HorizontalOptions="Start"
                             Margin="0,0,0,32">
            <Label Text="{Binding User.FirstName, StringFormat='Hello, {0}!'}"
                   FontSize="56"
                   Margin="0,16,0,8" />

            <Label Text="{Binding User.Points, StringFormat='Points: {0}'}"
                   FontSize="64"
                   FontAttributes="Bold"
                   Margin="0,0,0,0" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Margin="0, 0, 0, 0">
            <Label Text="We thought you might like these recommendations!" 
                   TextColor="White" 
                   FontSize="16" />

            <Grid ColumnDefinitions="Auto, *">
                <Label Grid.Column="0" Text="Items:" TextColor="White" FontSize="24" VerticalOptions="Center" Margin="0,0,10,0"/>

                <CollectionView Grid.Column="1" 
                        ItemsSource="{Binding RecommendedItems}" 
                        HeightRequest="80">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="Gray" StrokeThickness="2" BackgroundColor="#222" Padding="5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToItemDetailCommand}" 
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout Spacing="10">
                                    <Image Source="camera_icon.png" WidthRequest="40" HeightRequest="40" />
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding Name}" TextColor="White" FontSize="14" />
                                        <Label Text="{Binding Price, StringFormat='${0}'}" TextColor="White" FontSize="14" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid ColumnDefinitions="Auto, *" Margin="0, 10, 0, 0">
                <Label Grid.Column="0" Text="Offers:" TextColor="White" FontSize="24" VerticalOptions="Center" Margin="0,0,10,0"/>

                <CollectionView Grid.Column="1" 
                        ItemsSource="{Binding RecommendedOffers}" 
                        HeightRequest="80">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="Gray" StrokeThickness="2" BackgroundColor="#222" Padding="5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToOfferDetailCommand}" 
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <VerticalStackLayout VerticalOptions="Center" MinimumWidthRequest="120">
                                    <Label Text="{Binding Title}" TextColor="White" FontSize="14" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="2"
                             HorizontalOptions="Start"
                             Margin="0,0,0,24">
            <Label Text="Notifications"
                   FontSize="64"
                   FontAttributes="Bold"
                   Margin="0,0,0,8"/>

            <CollectionView ItemsSource="{Binding Notifications}" Margin="16">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Notification">
                        <Border Stroke="Gray" StrokeThickness="1" Padding="10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToNotificationCommand}" 
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="0">
                                <Label Text="{Binding Timestamp, StringFormat='{0}: '}" FontSize="8" TextColor="Gray" />
                                <Label Text="{Binding Header}" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="3"
                     HorizontalOptions="Start"
                     Margin="0,0,0,16">
            <Label Text="Purchase History"
                   FontSize="64"
                   FontAttributes="Bold"
                   Margin="0,0,0,8"/>

            <CollectionView ItemsSource="{Binding PurchaseHistory}" Margin="16">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Transaction">
                        <Border Stroke="Gray" StrokeThickness="1" Padding="10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToTransactionCommand}" 
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="0">
                                <Label Text="{Binding Timestamp, StringFormat='{0}: '}" FontSize="8" TextColor="Gray" />
                                <Label Text="{Binding TotalSpent, StringFormat='${0}'}" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </Grid>
</ContentPage>