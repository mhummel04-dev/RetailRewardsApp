<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.LoginPage">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*" Padding="24">

      <!--  <Image Grid.Row="0" Source="trademark.png" Aspect="AspectFit" HorizontalOptions="Start"/> 
        for when i get my logo image made, but till then: -->
        <Label Grid.Row="0"
               Text="C Custom"
               FontSize="16"
               HorizontalOptions="Start"/>

        <Label Grid.Row="1"
               Text="BUSINESS"
               FontSize="64"
               FontAttributes="Bold"
               Margin="0,160,0,64"
               FontFamily="{StaticResource SelectedBusinessFont}"
               HorizontalOptions="Center" />

        <Button Grid.Row="2"
                Text="Login"
                Command="{Binding LoginCommand}"
                HeightRequest="50"
                Margin="0,0,0,16"
                />

        <Label Grid.Row="3"
               Text="OR"
               FontSize="16"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,16"/>

        <Button Grid.Row="4"
                Text="Sign up"
                Command="{Binding SignUpCommand}"
                HeightRequest="50"
                Margin="0,0,0,16"/>

    </Grid>
    
</ContentPage>
