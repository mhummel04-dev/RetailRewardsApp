<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="RetailRewardsApp.Core.Models"
             x:Class="RetailRewardsApp.Mobile.Views.OffersPage"
             Title="OffersPage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to your offers!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding BindingOffers}" Margin="20">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Offer">
                    <Frame HasShadow="True" Margin="0,0,0,10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Description}" FontSize="18" FontAttributes="Bold" />
                            <!-- add items and point cost later due to current complexity -->
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>


        <Button
            Text="Click here to see a detailed view of the offer!"
            Command="{Binding GoToOfferDetailCommand}"
        />

    </VerticalStackLayout>
</ContentPage>