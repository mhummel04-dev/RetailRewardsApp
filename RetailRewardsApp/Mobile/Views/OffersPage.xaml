<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.OffersPage"
             xmlns:models="RetailRewardsApp.Core.Models"
             xmlns:vm="clr-namespace:RetailRewardsApp.Mobile.ViewModels"
             Title="OffersPage">

    <Grid RowDefinitions="Auto, *" Padding="0">

        <Border Grid.Row="0" 
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
            Padding="16,10"
            StrokeThickness="0,0,0,1">
            <Border.StrokeShape>
                <Line HeightRequest="1" />
            </Border.StrokeShape>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Label Text="{Binding CurrentLocation.Name, FallbackValue='Select Location'}"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />

                <ImageButton Source="chevron_down.png" 
                         Command="{Binding ChangeLocationCommand}"
                         HeightRequest="20"
                         VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" 
                    ItemsSource="{Binding Offers}"
                    SelectionMode="None"
                    Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Offer">
                    <Border Stroke="Gray" 
                        StrokeThickness="1" 
                        Margin="0,0,0,12" 
                        Padding="12"
                        StrokeShape="RoundRectangle 8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OfferViewModel}}, Path=GoToOfferDetailCommand}" 
                            CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                            <Image Grid.Column="0" 
                               Source="{Binding ImageUrl}" 
                               WidthRequest="60" 
                               HeightRequest="60"
                               Aspect="AspectFit"/>

                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Description}" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="|" TextColor="Gray"/>
                                <Label Text="{Binding PointCost, StringFormat='{0}'}" FontSize="16"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>