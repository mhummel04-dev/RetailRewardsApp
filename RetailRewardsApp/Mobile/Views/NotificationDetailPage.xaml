<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.NotificationDetailPage"
             x:DataType="vm:NotificationDetailViewModel"
             xmlns:vm="clr-namespace:RetailRewardsApp.Mobile.ViewModels"
             Title="NotificationDetailPage">
    <VerticalStackLayout Padding="20">
        <Label Text="{Binding SelectedNotification.Header}" FontSize="24" FontAttributes="Bold" />
        <Label Text="{Binding SelectedNotification.Timestamp, StringFormat='Received: {0:f}'}" />
        <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />
        <Label Text="{Binding SelectedNotification.Message}" FontSize="16" />
    </VerticalStackLayout>
</ContentPage>