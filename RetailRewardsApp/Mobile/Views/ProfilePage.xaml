<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.ProfilePage"
             xmlns:vm="clr-namespace:RetailRewardsApp.Mobile.ViewModels"
             xmlns:models="clr-namespace:RetailRewardsApp.Core.Models"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="24">

            <Border Stroke="Gray" 
                    StrokeThickness="1" 
                    Padding="16" 
                    StrokeShape="RoundRectangle 12">

                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto">

                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="{Binding FullName}" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               Margin="0,0,0,8" />

                        <Label Text="{Binding User.Points, StringFormat='Points: {0}'}" 
                               FontSize="16" />

                        <Label Text="{Binding User.Birthday, StringFormat='DOB: {0:D}'}" 
                               FontSize="16" />

                        <Label Text="{Binding User.EmailAddress, StringFormat='Email: {0}'}" 
                               FontSize="16" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1" 
                            Text="Edit Profile" 
                            Command="{Binding GoToEditProfileCommand}"
                            VerticalOptions="Start" 
                            Padding="12,0"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                            BorderColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                            BorderWidth="1"/>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label Text="Notifications" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       Margin="8,0,0,0"/>

                <CollectionView ItemsSource="{Binding Notifications}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Notification">

                            <Border Stroke="Gray" 
                                    StrokeThickness="1" 
                                    Margin="0,0,0,10" 
                                    Padding="16"
                                    StrokeShape="RoundRectangle 8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileViewModel}}, Path=GoToNotificationCommand}" 
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" 
                                           Text="{Binding Header}" 
                                           FontAttributes="Bold" 
                                           FontSize="16"/>

                                    <Label Grid.Column="1" 
                                           Text="{Binding Timestamp, StringFormat='{0:M/dd}'}" 
                                           TextColor="Gray" 
                                           FontSize="12" 
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Purchase History" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       Margin="8,0,0,0"/>

                <CollectionView ItemsSource="{Binding Transactions}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Transaction">

                            <Border Stroke="Gray" 
                                    StrokeThickness="1" 
                                    Margin="0,0,0,10" 
                                    Padding="16"
                                    StrokeShape="RoundRectangle 8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileViewModel}}, Path=GoToTransactionCommand}" 
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding Business.Name}" 
                                               FontAttributes="Bold" 
                                               FontSize="16"/>
                                        <Label Text="{Binding Timestamp, StringFormat='{0:M/dd/yy}'}" 
                                               TextColor="Gray" 
                                               FontSize="12" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="1" 
                                           Text="{Binding TotalSpent, StringFormat='${0:F2}'}" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>