<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.ProfilePage"
             Title="ProfilePage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to your profile!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Button
            Text="Click here to edit your profile!"
            Command="{Binding GoToEditProfileCommand}"
        />

        <Button
            Text="Click here to see a detailed view of a notification!"
            Command="{Binding GoToNotificationCommand}"
        />

        <Button
            Text="Click here to see a detailed view of a previous transaction!"
            Command="{Binding GoToHistoryCommand}"
        />

    </VerticalStackLayout>
</ContentPage>