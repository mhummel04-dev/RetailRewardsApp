<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RetailRewardsApp.Mobile.Views.MenuPage"
             xmlns:models="RetailRewardsApp.Core.Models"
             Title="MenuPage">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to the Menu!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding BindingMenu}" Margin="20">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <Frame HasShadow="True" Margin="0,0,0,10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Price, StringFormat='${0}'}" FontSize="14"/>
                            <Label Text="{Binding Stock, StringFormat='Amt: {0}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
                        
        <Button
            Text="Click here to see a detailed view of an item!"
            Command="{Binding GoToItemDetailCommand}"
        />
        
    </VerticalStackLayout>
</ContentPage>